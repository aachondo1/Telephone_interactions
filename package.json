    "c8": "^11.0.0",
    "lucide-react": "^0.344.0",
    "pptxgenjs": "^4.0.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "recharts": "^3.8.1",
    "vitest": "4.1.6",
    "vitest-canvas-mock": "^1.1.4"
  },
  "devDependencies": {
    "@eslint/js": "^9.9.1",
    "@playwright/test": "^1.60.0",
    "@types/react": "^18.3.5",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "@vitest/coverage-v8": "4.1.6",
    "autoprefixer": "^10.4.18",
    "eslint": "^9.9.1",
